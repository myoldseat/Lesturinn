rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── recordings/{familyId}/{childKey}/{ts}/{file} ───────────────────────
    // Children upload their own recordings; all family members can read.
    match /recordings/{familyId}/{childKey}/{ts}/{fileName} {
      allow read: if request.auth != null &&
        request.auth.token.get('familyId', '') == familyId;
      allow write: if request.auth != null &&
        request.auth.token.get('familyId', '') == familyId &&
        request.auth.token.get('childKey', '') == childKey;
    }

    // ── covers/{familyId}/{childKey}/{ts}/{file} ───────────────────────────
    // child-view.js cover-upload path (5 segments).
    // Children or parents can upload covers; all family members can read.
    match /covers/{familyId}/{childKey}/{ts}/{fileName} {
      allow read: if request.auth != null &&
        request.auth.token.get('familyId', '') == familyId;
      allow write: if request.auth != null &&
        request.auth.token.get('familyId', '') == familyId && (
          request.auth.token.get('childKey', '') == childKey ||
          request.auth.token.get('role', '') == 'parent'
        );
    }

    // ── covers/{familyId}/{childKey}/{file} ────────────────────────────────
    // bookshelf.html cover-upload path (4 segments — filename includes ts).
    match /covers/{familyId}/{childKey}/{fileName} {
      allow read: if request.auth != null &&
        request.auth.token.get('familyId', '') == familyId;
      allow write: if request.auth != null &&
        request.auth.token.get('familyId', '') == familyId && (
          request.auth.token.get('childKey', '') == childKey ||
          request.auth.token.get('role', '') == 'parent'
        );
    }
  }
}
